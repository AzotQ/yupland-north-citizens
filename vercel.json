{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**/*",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/passport-holders", "dest": "/api/passport-holders.js" },
    { "src": "/(.*\\.(js|css|html))", "dest": "/public/$1" },
    { "src": "/",                     "dest": "/public/index.html" }
  ]
}
